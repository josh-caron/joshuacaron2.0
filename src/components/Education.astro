---
import { siteConfig } from "../config";
const hasEducation = siteConfig.education && siteConfig.education.length > 0;

function getInitials(name: string) {
  return name
    .split(/\s+/)
    .filter(Boolean)
    .slice(0, 2)
    .map((word) => word[0])
    .join("")
    .toUpperCase();
}
---

{
  hasEducation && (
    <section id="education" class="px-4 py-2 sm:px-6 sm:py-3 md:px-8 lg:px-12">
      <div class="mx-auto max-w-4xl">
        <div class="rounded-xl border border-gray-200 bg-white p-5 shadow-sm sm:p-6 md:p-8">
          <div class="mb-4 flex items-center gap-2.5 sm:mb-5">
            <svg
              xmlns="http://www.w3.org/2000/svg"
              width="22"
              height="22"
              viewBox="0 0 24 24"
              fill="none"
              stroke={siteConfig.accentColor}
              stroke-width="2"
              stroke-linecap="round"
              stroke-linejoin="round"
            >
              <path stroke="none" d="M0 0h24v24H0z" fill="none" />
              <path d="M22 9l-10 -4l-10 4l10 4l10 -4v6" />
              <path d="M6 10.6v5.4a6 3 0 0 0 12 0v-5.4" />
            </svg>
            <h2 class="text-xl font-bold text-gray-900 sm:text-2xl">
              Education
            </h2>
          </div>

          <div class="divide-y divide-gray-100">
            {siteConfig.education.map((edu) => (
              <div class="flex gap-3 py-4 first:pt-0 last:pb-0 sm:gap-4 sm:py-5">
                <div
                  class="flex h-11 w-11 flex-shrink-0 items-center justify-center rounded-lg text-sm font-bold text-white sm:h-13 sm:w-13 md:h-14 md:w-14 md:text-base"
                  style={`background-color: ${siteConfig.accentColor}`}
                >
                  {getInitials(edu.school)}
                </div>
                <div class="min-w-0 flex-1">
                  <div class="flex flex-col sm:flex-row sm:items-baseline sm:justify-between sm:gap-4">
                    <h3 class="text-base font-semibold text-gray-900 sm:text-lg">
                      {edu.school}
                    </h3>
                    <span class="text-sm text-gray-500">{edu.dateRange}</span>
                  </div>
                  {edu.degree && (
                    <p class="text-sm text-gray-600 sm:text-base">
                      {edu.degree}
                    </p>
                  )}

                  {edu.achievements && edu.achievements.length > 0 && (
                    <ul class="mt-2 space-y-1.5">
                      {edu.achievements.map((achievement) => (
                        <li class="flex items-start gap-2">
                          <span class="mt-2 h-1 w-1 flex-shrink-0 rounded-full bg-gray-400" />
                          <span class="text-sm text-gray-600 sm:text-base">
                            {achievement}
                          </span>
                        </li>
                      ))}
                    </ul>
                  )}

                  {edu.relevantCourses && edu.relevantCourses.length > 0 && (
                    <details class="group mt-3 rounded-lg border border-gray-100 bg-gray-50 px-3 py-2.5 sm:px-4 sm:py-3">
                      <summary class="flex cursor-pointer list-none items-center justify-between gap-4 text-sm font-medium text-gray-800 sm:text-base">
                        <span>Relevant Courses</span>
                        <span class="text-gray-400 transition-transform duration-200 group-open:rotate-180">
                          ▾
                        </span>
                      </summary>
                      <ul class="mt-3 flex flex-wrap gap-2">
                        {edu.relevantCourses.map((course) => (
                          <li class="rounded-full border border-gray-200 bg-white px-3 py-1 text-xs text-gray-600 sm:text-sm">
                            {course}
                          </li>
                        ))}
                        {siteConfig.coursework && siteConfig.coursework.length > 0 && (
                          <li>
                            <button
                              onclick="const table = document.getElementById('courses-table'); table.classList.toggle('hidden'); this.textContent = table.classList.contains('hidden') ? '→ See All Courses' : '← Hide Courses'; if (!table.classList.contains('hidden')) { setTimeout(() => table.scrollIntoView({ behavior: 'smooth' }), 100); }"
                              class="cursor-pointer rounded-full border px-3 py-1 text-xs font-medium transition-colors sm:text-sm"
                              style={`border-color: ${siteConfig.accentColor}55; color: ${siteConfig.accentColor}; background-color: ${siteConfig.accentColor}0d`}
                            >
                              → See All Courses
                            </button>
                          </li>
                        )}
                      </ul>
                    </details>
                  )}
                </div>
              </div>
            ))}
          </div>

          {siteConfig.coursework && siteConfig.coursework.length > 0 && (
            <div id="courses-table" class="hidden mt-6 scroll-mt-20 border-t border-gray-100 pt-6">
              <div class="overflow-x-auto rounded-lg border border-gray-100">
                <table class="w-full">
                  <thead>
                    <tr class="border-b border-gray-200 bg-gray-50">
                      <th class="px-3 py-2.5 text-left text-xs font-semibold text-gray-900 sm:px-4 sm:py-3 sm:text-sm">
                        Course Code
                      </th>
                      <th class="px-3 py-2.5 text-left text-xs font-semibold text-gray-900 sm:px-4 sm:py-3 sm:text-sm">
                        Course Title
                      </th>
                      <th class="px-3 py-2.5 text-left text-xs font-semibold text-gray-900 sm:px-4 sm:py-3 sm:text-sm">
                        Grade
                      </th>
                      <th class="px-3 py-2.5 text-left text-xs font-semibold text-gray-900 sm:px-4 sm:py-3 sm:text-sm">
                        Semester
                      </th>
                      <th class="px-3 py-2.5 text-left text-xs font-semibold text-gray-900 sm:px-4 sm:py-3 sm:text-sm">
                        Description
                      </th>
                    </tr>
                  </thead>
                  <tbody>
                    {siteConfig.coursework.map((course, index) => (
                      <tr
                        class={`border-b border-gray-100 last:border-b-0 ${
                          index % 2 === 0 ? "bg-white" : "bg-gray-50"
                        } transition-colors hover:bg-blue-50`}
                      >
                        <td class="px-3 py-2.5 font-mono text-xs text-gray-600 sm:px-4 sm:py-3 sm:text-sm">
                          {course.code}
                        </td>
                        <td class="px-3 py-2.5 text-xs font-medium text-gray-900 sm:px-4 sm:py-3 sm:text-sm">
                          {course.title}
                        </td>
                        <td class="px-3 py-2.5 text-xs sm:px-4 sm:py-3 sm:text-sm">
                          <span
                            class={`inline-block rounded px-2 py-1 font-medium ${
                              course.grade === "IP"
                                ? "bg-blue-100 text-blue-700"
                                : "bg-green-100 text-green-700"
                            }`}
                          >
                            {course.grade}
                          </span>
                        </td>
                        <td class="px-3 py-2.5 text-xs text-gray-600 sm:px-4 sm:py-3 sm:text-sm">
                          {course.semester}
                        </td>
                        <td class="px-3 py-2.5 text-xs text-gray-600 sm:px-4 sm:py-3 sm:text-sm">
                          {course.description}
                        </td>
                      </tr>
                    ))}
                  </tbody>
                </table>
              </div>
            </div>
          )}
        </div>
      </div>
    </section>
  )
}
