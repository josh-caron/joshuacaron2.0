---
import { siteConfig } from "../config";
const hasEducation = siteConfig.education && siteConfig.education.length > 0;
---

{
  hasEducation && (
    <section id="education" class="p-8 sm:p-12 md:p-16 lg:p-24">
      <div>
        <div class="grid grid-cols-1 lg:grid-cols-12 gap-8 lg:gap-16 items-start">
          <div class="lg:col-span-4">
            <h2 class="text-3xl sm:text-4xl md:text-5xl xl:text-7xl font-bold text-gray-900">
              Education
            </h2>
            <div
              class="w-[75px] h-[5px] mt-2 rounded-full"
              style={`background-color: ${siteConfig.accentColor}`}
            />
          </div>

          <div class="lg:col-span-8">
            <div class="space-y-8">
              {siteConfig.education.map((edu) => (
                <div class="bg-white rounded-lg shadow-sm border border-gray-100 p-4 sm:p-5 md:p-6 hover:shadow-md transition-shadow duration-300">
                  <div class="flex flex-col sm:flex-row sm:items-start sm:justify-between mb-4">
                    <div>
                      <h3 class="text-xl sm:text-2xl font-semibold text-gray-900">
                        {edu.degree}
                      </h3>
                      <p
                        class="text-lg sm:text-xl"
                        style={`color: ${siteConfig.accentColor}`}
                      >
                        {edu.school}
                      </p>
                    </div>
                    <span class="text-sm sm:text-base text-gray-500 mt-2 sm:mt-0">
                      {edu.dateRange}
                    </span>
                  </div>

                  <ul class="space-y-2">
                    {edu.achievements.map((achievement) => (
                      <li class="flex items-start">
                        <span class="inline-block w-1.5 h-1.5 rounded-full bg-gray-400 mt-2 mr-3 flex-shrink-0" />
                        <span class="text-base sm:text-lg text-gray-600">
                          {achievement}
                        </span>
                      </li>
                    ))}
                  </ul>

                  {edu.relevantCourses && edu.relevantCourses.length > 0 && (
                    <details class="group mt-5 rounded-lg border border-gray-100 bg-gray-50 px-4 py-3">
                      <summary class="flex cursor-pointer list-none items-center justify-between gap-4 text-base sm:text-lg font-medium text-gray-800">
                        <span>Relevant Courses</span>
                        <span class="text-gray-400 transition-transform duration-200 group-open:rotate-180">
                          ▾
                        </span>
                      </summary>
                      <ul class="mt-3 flex flex-wrap gap-2">
                        {edu.relevantCourses.map((course) => (
                          <li class="rounded-full bg-white px-3 py-1 text-sm sm:text-base text-gray-600 border border-gray-200">
                            {course}
                          </li>
                        ))}
                        {siteConfig.coursework && siteConfig.coursework.length > 0 && (
                          <li>
                            <button
                              onclick="const table = document.getElementById('courses-table'); table.classList.toggle('hidden'); this.textContent = table.classList.contains('hidden') ? '→ See All Courses' : '← Hide Courses'; if (!table.classList.contains('hidden')) { setTimeout(() => table.scrollIntoView({ behavior: 'smooth' }), 100); }"
                              class="rounded-full bg-gradient-to-r from-blue-50 to-blue-100 px-4 py-1 text-sm sm:text-base text-blue-700 border border-blue-300 hover:from-blue-100 hover:to-blue-200 transition-all cursor-pointer font-medium"
                            >
                              → See All Courses
                            </button>
                          </li>
                        )}
                      </ul>
                    </details>
                  )}
                </div>
              ))}
            </div>
          </div>
        </div>
      </div>

      {siteConfig.coursework && siteConfig.coursework.length > 0 && (
        <div id="courses-table" class="hidden mt-16 scroll-mt-20">
            <div class="overflow-x-auto bg-white rounded-lg shadow-sm border border-gray-100">
              <table class="w-full">
                <thead>
                  <tr class="border-b border-gray-200 bg-gray-50">
                    <th class="px-4 sm:px-6 py-3 sm:py-4 text-left text-sm sm:text-base font-semibold text-gray-900">
                      Course Code
                    </th>
                    <th class="px-4 sm:px-6 py-3 sm:py-4 text-left text-sm sm:text-base font-semibold text-gray-900">
                      Course Title
                    </th>
                    <th class="px-4 sm:px-6 py-3 sm:py-4 text-left text-sm sm:text-base font-semibold text-gray-900">
                      Grade
                    </th>
                    <th class="px-4 sm:px-6 py-3 sm:py-4 text-left text-sm sm:text-base font-semibold text-gray-900">
                      Semester
                    </th>
                    <th class="px-4 sm:px-6 py-3 sm:py-4 text-left text-sm sm:text-base font-semibold text-gray-900">
                      Description
                    </th>
                  </tr>
                </thead>
                <tbody>
                  {siteConfig.coursework.map((course, index) => (
                    <tr
                      class={`border-b border-gray-100 ${
                        index % 2 === 0 ? "bg-white" : "bg-gray-50"
                      } hover:bg-blue-50 transition-colors`}
                    >
                      <td class="px-4 sm:px-6 py-3 sm:py-4 text-sm sm:text-base font-mono text-gray-600">
                        {course.code}
                      </td>
                      <td class="px-4 sm:px-6 py-3 sm:py-4 text-sm sm:text-base font-medium text-gray-900">
                        {course.title}
                      </td>
                      <td class="px-4 sm:px-6 py-3 sm:py-4 text-sm sm:text-base">
                        <span
                          class={`inline-block px-2 py-1 rounded font-medium ${
                            course.grade === "IP"
                              ? "bg-blue-100 text-blue-700"
                              : "bg-green-100 text-green-700"
                          }`}
                        >
                          {course.grade}
                        </span>
                      </td>
                      <td class="px-4 sm:px-6 py-3 sm:py-4 text-sm sm:text-base text-gray-600">
                        {course.semester}
                      </td>
                      <td class="px-4 sm:px-6 py-3 sm:py-4 text-sm sm:text-base text-gray-600">
                        {course.description}
                      </td>
                    </tr>
                  ))}
                </tbody>
              </table>
            </div>
          </div>
        )}
    </section>
  )
}
