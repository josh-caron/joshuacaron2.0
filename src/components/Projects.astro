---
import { siteConfig } from "../config";
const hasProjects = siteConfig.projects && siteConfig.projects.length > 0;
---

{
  hasProjects && (
    <section id="projects" class="px-4 py-2 sm:px-6 sm:py-3 md:px-8 lg:px-12">
      <div class="mx-auto max-w-4xl">
        <div class="rounded-xl border border-gray-200 bg-white p-5 shadow-sm sm:p-6 md:p-8">
          <div class="mb-4 flex items-center gap-2.5 sm:mb-5">
            <svg
              xmlns="http://www.w3.org/2000/svg"
              width="22"
              height="22"
              viewBox="0 0 24 24"
              fill="none"
              stroke={siteConfig.accentColor}
              stroke-width="2"
              stroke-linecap="round"
              stroke-linejoin="round"
            >
              <path stroke="none" d="M0 0h24v24H0z" fill="none" />
              <path d="M7 8l-4 4l4 4" />
              <path d="M17 8l4 4l-4 4" />
              <path d="M14 4l-4 16" />
            </svg>
            <h2 class="text-xl font-bold text-gray-900 sm:text-2xl">
              Projects
            </h2>
          </div>

          <div class="space-y-4">
            {siteConfig.projects.map((project, index) => {
              const Component = project.link ? "a" : "div";
              const linkProps = project.link
                ? {
                    href: project.link,
                    target: "_blank",
                    rel: "noopener noreferrer",
                  }
                : {};

              return (
                <div class="group relative">
                  <Component
                    {...linkProps}
                    class={`block relative rounded-lg border border-gray-200 bg-gray-50 p-4 transition-all duration-300 sm:p-5 ${
                      project.link
                        ? "hover:-translate-y-0.5 hover:border-gray-300 hover:bg-white hover:shadow-md"
                        : ""
                    }`}
                  >
                    {project.link && (
                      <div class="absolute top-4 right-4 flex h-9 w-9 items-center justify-center rounded-full bg-gray-900 text-white transition-all duration-300 group-hover:bg-gray-700 sm:top-5 sm:right-5">
                        <svg
                          class="h-4 w-4 transition-transform duration-300 group-hover:translate-x-0.5 group-hover:-translate-y-0.5"
                          fill="none"
                          stroke="currentColor"
                          viewBox="0 0 24 24"
                        >
                          <path
                            stroke-linecap="round"
                            stroke-linejoin="round"
                            stroke-width="2"
                            d="M7 17L17 7M17 7H7M17 7V17"
                          />
                        </svg>
                      </div>
                    )}

                    <div class="space-y-3">
                      <div>
                        <span
                          class="text-sm font-mono"
                          style={{ color: siteConfig.accentColor }}
                        >
                          0{index + 1}
                        </span>
                        <h3 class="mt-1 text-lg font-semibold text-gray-900 sm:text-xl">
                          {project.name}
                        </h3>
                      </div>

                      <p
                        class={`text-sm leading-relaxed text-gray-600 sm:text-base ${project.link ? "pr-10 sm:pr-12" : ""}`}
                      >
                        {project.description}
                      </p>

                      {project.skills && project.skills.length > 0 && (
                        <div class="flex flex-wrap gap-1.5 pt-1">
                          {project.skills.map((skill) => (
                            <span
                              class={`rounded-md px-2.5 py-1 text-xs font-medium text-white transition-all duration-300 sm:text-sm ${
                                project.link ? "group-hover:opacity-90" : ""
                              }`}
                              style={`background-color: ${siteConfig.accentColor}`}
                            >
                              {skill}
                            </span>
                          ))}
                        </div>
                      )}
                    </div>
                  </Component>
                </div>
              );
            })}
          </div>
        </div>
      </div>
    </section>
  )
}
