---
import { siteConfig } from "../config";
---

<div
  id="hero"
  class="px-4 pt-20 pb-6 sm:px-6 sm:pt-24 sm:pb-8 md:px-8 lg:px-12"
  style={`--accent-color: ${siteConfig.accentColor}`}
>
  <div class="mx-auto max-w-4xl animate-fade-in">
    <div
      class="overflow-hidden rounded-xl border border-gray-200 bg-white shadow-sm"
    >
      <!-- Banner -->
      <div
        class="relative h-28 sm:h-36 md:h-44"
        style={`background: linear-gradient(120deg, ${siteConfig.accentColor} 0%, ${siteConfig.accentColor}cc 45%, ${siteConfig.accentColor}88 100%)`}
      >
        <svg
          aria-hidden="true"
          class="absolute inset-0 h-full w-full opacity-20"
        >
          <defs>
            <pattern
              id="hero-grid"
              width="28"
              height="28"
              patternUnits="userSpaceOnUse"
            >
              <path
                d="M28 0H0V28"
                fill="none"
                stroke="white"
                stroke-width="1"
              ></path>
            </pattern>
          </defs>
          <rect width="100%" height="100%" fill="url(#hero-grid)"></rect>
        </svg>
      </div>

      <div class="px-4 pb-6 sm:px-6 sm:pb-8 md:px-10 md:pb-10">
        <div
          class="-mt-10 flex flex-col items-start gap-4 sm:-mt-14 sm:flex-row sm:items-end sm:justify-between md:-mt-16"
        >
          <img
            src="/headshot.jpg"
            alt="Josh Caron"
            class="h-20 w-20 rounded-full border-4 border-white object-cover shadow-lg sm:h-28 sm:w-28 md:h-32 md:w-32"
          />

          <!-- Action buttons -->
          <div
            class="flex flex-wrap gap-2 sm:gap-3 sm:pb-1 animate-fade-in animation-delay-400"
          >
            {
              siteConfig.social?.email && (
                <a
                  href={`mailto:${siteConfig.social.email}`}
                  class="rounded-full px-4 py-1.5 text-sm font-semibold text-white shadow-sm transition-opacity duration-200 hover:opacity-90"
                  style={`background-color: ${siteConfig.accentColor}`}
                >
                  Email
                </a>
              )
            }
            {
              siteConfig.social?.linkedin && (
                <a
                  href={siteConfig.social.linkedin}
                  target="_blank"
                  rel="noopener noreferrer"
                  class="rounded-full border-2 px-4 py-1.5 text-sm font-semibold transition-colors duration-200 hover:bg-[var(--accent-color)] hover:text-white"
                  style={`border-color: ${siteConfig.accentColor}; color: ${siteConfig.accentColor}`}
                >
                  LinkedIn
                </a>
              )
            }
            {
              siteConfig.social?.github && (
                <a
                  href={siteConfig.social.github}
                  target="_blank"
                  rel="noopener noreferrer"
                  class="rounded-full border-2 border-gray-300 px-4 py-1.5 text-sm font-semibold text-gray-700 transition-colors duration-200 hover:border-gray-400 hover:bg-gray-50"
                >
                  GitHub
                </a>
              )
            }
            {
              siteConfig.social?.resume && (
                <a
                  href={siteConfig.social.resume}
                  target="_blank"
                  rel="noopener noreferrer"
                  class="rounded-full border-2 border-gray-300 px-4 py-1.5 text-sm font-semibold text-gray-700 transition-colors duration-200 hover:border-gray-400 hover:bg-gray-50"
                >
                  Resume
                </a>
              )
            }
          </div>
        </div>

        <div class="mt-4 sm:mt-6">
          <h1
            class="text-pretty text-2xl font-bold tracking-tight text-gray-900 sm:text-3xl md:text-4xl animate-fade-in animation-delay-200"
          >
            {siteConfig.name}
          </h1>
          <p
            class="mt-1.5 text-pretty text-base font-medium text-gray-600 sm:text-lg md:text-xl animate-fade-in animation-delay-300"
          >
            {siteConfig.title}
          </p>

          {
            siteConfig.funFacts && siteConfig.funFacts.length > 0 && (
              <div class="mt-4 flex h-10 items-center overflow-hidden border-t border-gray-100 pt-4 sm:h-12">
                <div class="fun-facts-carousel w-full">
                  {siteConfig.funFacts.map((fact, index) => (
                    <p
                      class="text-sm font-medium text-gray-500 sm:text-base"
                      style={`--fact-index: ${index}`}
                    >
                      <span style={{ color: siteConfig.accentColor }}>✦</span>{" "}
                      {fact}
                    </p>
                  ))}
                </div>
              </div>
            )
          }
        </div>
      </div>
    </div>
  </div>
</div>

<style>
  @keyframes fadeIn {
    from {
      opacity: 0;
      transform: translateY(20px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  .animate-fade-in {
    animation: fadeIn 0.8s ease-out forwards;
    opacity: 0;
  }

  .animation-delay-200 {
    animation-delay: 0.2s;
  }

  .animation-delay-300 {
    animation-delay: 0.3s;
  }

  .animation-delay-400 {
    animation-delay: 0.4s;
  }
</style>
